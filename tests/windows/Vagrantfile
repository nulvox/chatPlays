# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.box = "jborean93/WindowsServer2019"
  config.vm.communicator = "winrm"
  config.vm.hostname = "chatplays-win"

  # Disable default synced folder — we copy files via provisioning instead,
  # avoiding SMB/rsync dependency issues with Windows guests on libvirt.
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider :libvirt do |libvirt|
    libvirt.cpus = 2
    libvirt.memory = 4096

    # Use a dedicated network bridge so we don't collide with the host's
    # default libvirt resources (virbr0 / default network).
    libvirt.management_network_name    = "chatplays-mgmt"
    libvirt.management_network_address = "192.168.124.0/24"
  end

  # Upload the project tree into the VM via WinRM file provisioner.
  config.vm.provision "file",
    source: "../../",
    destination: "C:\\chatplays"

  config.vm.provision "shell",
    path: "provision.ps1",
    powershell_elevated_interactive: false
end
