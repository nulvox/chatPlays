# chatPlays — udev rules for virtual and physical game controllers
#
# Install:
#   sudo cp 99-chatplays.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# These rules:
#   1. Allow non-root access to /dev/uinput so chatPlays can create virtual
#      controllers without running as root (user must be in the "input" group).
#   2. Tag chatPlays virtual gamepads by their unique device name so Steam and
#      other software can distinguish them from real controllers.
#   3. Ensure real Xbox and GameSir controllers use the correct driver and are
#      never confused with chatPlays virtual devices.

# ── /dev/uinput access for the "input" group ────────────────────────────────
KERNEL=="uinput", SUBSYSTEM=="misc", GROUP="input", MODE="0660"

# ── chatPlays virtual gamepads ──────────────────────────────────────────────
# Matched by device name (set by uinput in linux.py) rather than VID/PID.
# This is guaranteed unique — no physical hardware will ever report this name.
SUBSYSTEM=="input", ATTRS{name}=="chatPlays Virtual Gamepad*", \
    ENV{ID_INPUT_JOYSTICK}="1", \
    TAG+="chatplays", \
    MODE="0660", GROUP="input"

# ── GameSir controllers ────────────────────────────────────────────────────
# GameSir gamepads (VID 3537) in Xbox compatibility mode — bind to xpad so
# the kernel does not fall through to a wrong or generic driver.
SUBSYSTEM=="usb", ATTRS{idVendor}=="3537", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="gamesir"
# GameSir over Bluetooth (reports as Xbox 360 controller, 045e:028e on BT bus)
SUBSYSTEM=="input", ATTRS{name}=="GameSir*", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="gamesir-bt"

# ── Real Xbox controllers ──────────────────────────────────────────────────
# Explicitly tag physical Microsoft controllers as joysticks so the system
# always uses the correct driver.
#
# Xbox 360 wired controller
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="028e", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xbox360"
# Xbox 360 wireless receiver
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0719", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xbox360"
# Xbox One controller (USB)
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="02d1", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxone"
# Xbox One S controller (USB)
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="02ea", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxone"
# Xbox One S controller (Bluetooth)
SUBSYSTEM=="input", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="02fd", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxone-bt"
# Xbox Series X|S controller (USB)
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0b12", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxseriesx"
# Xbox Series X|S controller (Bluetooth)
SUBSYSTEM=="input", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0b22", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxseriesx-bt"
# Xbox Series X|S controller (Bluetooth, legacy PID)
SUBSYSTEM=="input", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0b13", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxseriesx-bt"
# Xbox Elite Series 2 controller
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0b00", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxelite"
# Xbox Adaptive Controller
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0b0a", \
    ENV{ID_INPUT_JOYSTICK}="1", TAG+="xboxadaptive"
